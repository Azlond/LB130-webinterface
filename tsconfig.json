{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "lib": ["ESNext", "DOM"],
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": [".", "src", "types"],
  "exclude": ["dist", "node_modules"]
}
